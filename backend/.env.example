
# Supabase: использовать Session Pooler (порт 5432), НЕ Transaction Pooler (6543)
# Pooler URL: supabase.com → Project Settings → Database → Connection string → Session
DATABASE_URL="postgresql://postgres.xxxxxxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
# DIRECT_URL нужен для prisma migrate/db push (можно тот же Session Pooler)
DIRECT_URL="postgresql://postgres.xxxxxxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

JWT_SECRET="change-this-to-random-secret-min-32-chars"
ANTHROPIC_API_KEY="sk-ant-..."
FRONTEND_URL="http://localhost:5173"
PORT=3001

# Supabase Storage (для загрузки фото и видео)
# Взять из: supabase.com → Project Settings → API
SUPABASE_URL="https://xxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."   # service_role key (не anon!)

# Telegram Bot (заполнить после создания бота у @BotFather)
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_BOT_USERNAME="YourBotName"   # без @, например: MealBotRu
TELEGRAM_WEBHOOK_URL="https://yourdomain.com/telegram/webhook"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Resend (отправка email)
RESEND_API_KEY="re_..."
RESEND_FROM="MealBot <noreply@smarussya.ru>"

# Web Push (VAPID) — сгенерировать: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(JSON.stringify(k))"
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@yourdomain.com"

# Хранилище медиафайлов: supabase (по умолчанию, smarussya.ru) | local (mealily.ru)
STORAGE_DRIVER="supabase"
# Для STORAGE_DRIVER=local:
MEDIA_DIR="/var/www/mealily-media"
MEDIA_PUBLIC_URL="https://mealily.ru/media"
