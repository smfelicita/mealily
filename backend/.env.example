
# БД: локальная PostgreSQL на прод-сервере (Москва). Supabase больше НЕ используется.
DATABASE_URL="postgresql://mealbot:password@localhost:5432/mealbot"
# DIRECT_URL нужен для prisma migrate/db push (для локальной БД — тот же URL)
DIRECT_URL="postgresql://mealbot:password@localhost:5432/mealbot"

JWT_SECRET="change-this-to-random-secret-min-32-chars"
ANTHROPIC_API_KEY="sk-ant-..."
FRONTEND_URL="http://localhost:5173"
PORT=3001

# Supabase Storage — НЕ используется в проде (медиа на local-диске, см. STORAGE_DRIVER ниже).
# Эти переменные нужны только если временно вернуть STORAGE_DRIVER=supabase.
# SUPABASE_URL="https://xxxxxxxxxx.supabase.co"
# SUPABASE_SERVICE_KEY="eyJ..."   # service_role key (не anon!)

# Telegram Bot (заполнить после создания бота у @BotFather)
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_BOT_USERNAME="YourBotName"   # без @, например: mealily_bot
TELEGRAM_WEBHOOK_URL="https://yourdomain.com/telegram/webhook"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Яндекс OAuth (oauth.yandex.ru → создать приложение, Redirect URI: https://mealily.ru/auth/yandex/callback)
YANDEX_CLIENT_ID="your-yandex-client-id"
YANDEX_CLIENT_SECRET="your-yandex-client-secret"

# Unisender Go (отправка email — транзакционные письма)
UNISENDER_GO_API_KEY="your-unisender-go-api-key"
MAIL_FROM="Meality <noreply@mealily.ru>"
# Необязательно (по умолчанию goapi.unisender.ru): UNISENDER_GO_API_URL=

# Web Push (VAPID) — сгенерировать: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(JSON.stringify(k))"
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@yourdomain.com"

# Хранилище медиафайлов: local (используется в проде — диск + nginx) | supabase (legacy)
STORAGE_DRIVER="local"
# Для STORAGE_DRIVER=local обязательны:
MEDIA_DIR="/var/www/mealily-media"
MEDIA_PUBLIC_URL="https://mealily.ru/media"
