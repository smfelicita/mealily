// This is your Prisma schema file

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Перечисления ────────────────────────────────────────────────────────────

enum Role {
  USER
  PRO
  ADMIN
}

enum GroupRole {
  OWNER
  MEMBER
}

enum GroupType {
  FAMILY
  REGULAR
}

enum DishVisibility {
  PRIVATE
  PUBLIC
  FAMILY
  ALL_GROUPS
}

enum DishStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MealCategory {
  SOUP
  SALAD
  MAIN
  SIDE
  DESSERT
  DRINK
  BAKERY
  SAUCE
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  ANYTIME
}

// ─── Пользователи ────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  passwordHash     String?
  name             String?
  telegramId          String?   @unique
  telegramUsername    String?
  pendingTelegramLink          String?   @unique
  pendingTelegramLinkExpiresAt DateTime?
  webLoginToken       String?   @unique
  webLoginTokenAt     DateTime?
  phone            String?   @unique
  phoneVerified    Boolean   @default(false)
  googleId         String?   @unique
  yandexId         String?   @unique
  emailVerified    Boolean   @default(false)
  role             Role      @default(USER)
  isActive         Boolean   @default(true)
  tokenVersion     Int       @default(0)
  subscriptionUntil DateTime?
  aiMessagesDay    Int       @default(0)
  aiMessagesDate   DateTime?
  timezone                 String    @default("Europe/Moscow")
  lastActiveAt             DateTime?
  lastDailySuggestSentAt   DateTime?
  lastFridgeReminderSentAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  fridge              FridgeItem[]
  chatHistory         ChatMessage[]
  dishes              Dish[]
  customIngredients   Ingredient[]
  ownedGroups         Group[]
  groupMembers        GroupMember[]
  mealPlans           MealPlan[]
  pushSubscriptions   PushSubscription[]
  favorites           Favorite[]
  comments            Comment[]
  sentInvites         GroupInvite[]

  @@map("users")
}

// ─── Ингредиенты и холодильник ───────────────────────────────────────────────

model Ingredient {
  id       String  @id @default(cuid())
  name     String  @unique
  nameRu   String
  nameEn   String?
  category String
  emoji    String?

  // КБЖУ на 100г
  protein Float?
  fat     Float?
  carbs   Float?

  // Средний вес 1 штуки в граммах (для unit="шт")
  avgWeightG Float?

  // Дефолтное количество для холодильника
  defaultQuantity Float?
  defaultUnit     String?

  // Базовый продукт (соль, масло и т.д.) — не требуется в холодильнике
  isBasic Boolean @default(false)

  // Игнорировать при фильтрации по холодильнику (специи, приправы)
  ignoreInFridgeFilter Boolean @default(false)

  // Кастомные ингредиенты пользователей
  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  isPublic Boolean @default(true)

  dishes   DishIngredient[]
  fridge   FridgeItem[]
  aliases  IngredientAlias[]

  @@map("ingredients")
}

model IngredientAlias {
  id           String     @id @default(cuid())
  alias        String     @unique
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@map("ingredient_aliases")
}

model FridgeItem {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  groupId       String?
  group         Group?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  quantityValue Float?
  quantityUnit  String?
  addedAt       DateTime   @default(now())
  expiresAt     DateTime?

  @@index([userId, groupId])
  @@index([groupId])
  @@map("fridge_items")
}

// ─── Блюда ───────────────────────────────────────────────────────────────────

model Dish {
  id          String         @id @default(cuid())
  name        String
  description String?
  categories  MealCategory[]
  cuisine     String?
  mealTime    MealType[]
  tags        String[]
  cookTime    Int?
  difficulty  String?
  calories    Int?
  imageUrl    String?
  images      String[]
  videoUrl    String?
  recipe      String?

  // Владение: null = системное блюдо от Meality
  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // Видимость
  visibility DishVisibility @default(PRIVATE)
  status     DishStatus     @default(APPROVED)

  // Группа: к какой группе принадлежит рецепт
  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  ingredients DishIngredient[]
  mealPlans   MealPlan[]
  favorites   Favorite[]
  comments    Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([visibility])
  @@index([groupId])
  @@index([createdAt])
  @@map("dishes")
}

model DishIngredient {
  id           String     @id @default(cuid())
  dishId       String
  dish         Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  amount       String?    // текстовое отображение (для совместимости)
  amountValue  Float?     // числовое значение
  unit         String?    // г | мл | шт | зубчик | пучок | щепотка
  toTaste      Boolean    @default(false) // "по вкусу" — не считается в КБЖУ и фильтрации
  optional     Boolean    @default(false)

  @@unique([dishId, ingredientId])
  @@map("dish_ingredients")
}

// ─── Группы ──────────────────────────────────────────────────────────────────

model Group {
  id                 String    @id @default(cuid())
  name               String
  description        String?
  avatarUrl          String?
  type               GroupType @default(REGULAR)
  ownerId            String
  owner              User      @relation(fields: [ownerId], references: [id])
  joinCode           String?   @unique  // только для REGULAR, TTL
  joinCodeExpiresAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  members     GroupMember[]
  dishes      Dish[]
  fridgeItems FridgeItem[]
  mealPlans   MealPlan[]
  invites     GroupInvite[]

  @@map("groups")
}

model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupInvite {
  id          String    @id @default(cuid())
  token       String    @unique
  groupId     String
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email       String
  invitedById String
  invitedBy   User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([invitedById, createdAt])
  @@index([email, createdAt])
  @@map("group_invites")
}

// ─── Коды верификации ─────────────────────────────────────────────────────────

model VerificationCode {
  id        String    @id @default(cuid())
  type      String    // "email" | "phone"
  target    String    // email или номер телефона
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([type, target])
  @@map("verification_codes")
}

// ─── План питания ─────────────────────────────────────────────────────────────

model MealPlan {
  id        String    @id @default(cuid())
  dishId    String
  dish      Dish      @relation(fields: [dishId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId   String?
  group     Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  mealType  MealType  @default(ANYTIME)
  date      DateTime?
  note      String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([groupId])
  @@map("meal_plans")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

// ─── Чат ─────────────────────────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // user | assistant
  content   String
  platform  String   // web | telegram
  createdAt DateTime @default(now())

  @@index([userId, platform])
  @@map("chat_messages")
}

// ─── Избранное ────────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dishId    String
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, dishId])
  @@map("favorites")
}

// ─── Аудит ───────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String   // DELETE_DISH, CHANGE_VISIBILITY, DEACTIVATE_USER, etc.
  targetId  String?  // id объекта над которым совершено действие
  payload   Json?    // diff или дополнительные данные
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Feature Flags ───────────────────────────────────────────────────────────

model FeatureFlag {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

// ─── AI Usage Logs ───────────────────────────────────────────────────────────

model AiUsageLog {
  id           String   @id @default(cuid())
  userId       String?
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  cost         Float    @default(0)
  status       String   // "success" | "error"
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

// ─── Комментарии ──────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  dishId    String
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dishId])
  @@index([userId])
  @@map("comments")
}
